{
  "manifest_version": 3,
  "name": "Parallax — Compare Wikipedia Editions",
  "version": "0.2.0",
  "description": "Read the same Wikipedia article from other language editions, translated side by side — see how each edition tells the story.",
  "icons": {
    "48": "icons/icon-48.png",
    "96": "icons/icon-96.png",
    "128": "icons/icon-128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "parallax@afginlabs.com",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["websiteContent", "browsingActivity"]
      }
    }
  },
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://*.wikipedia.org/*",
    "https://translate.googleapis.com/*",
    "https://stats.afginlabs.com/*"
  ],
  "background": {
    "scripts": [
      "lib/browser-polyfill.js",
      "lib/cache.js",
      "lib/providers-google.js",
      "background.js"
    ]
  },
  "action": {
    "default_title": "Parallax",
    "default_popup": "popup.html",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "content_scripts": [
    {
      "matches": ["https://*.wikipedia.org/wiki/*"],
      "js": [
        "lib/browser-polyfill.js",
        "lib/rtl.js",
        "lib/wiki.js",
        "lib/providers.js",
        "content.js"
      ],
      "run_at": "document_idle"
    }
  ]
}
